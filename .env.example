TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=[123456789]
YANDEX_DISK_TOKEN=
YANDEX_DISK_ROOT=disk:/Telegram Uploads

POSTGRES_DB=bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=change-me-before-production
DATABASE_URL=postgresql+asyncpg://bot:change-me-before-production@postgres:5432/bot
REDIS_URL=redis://redis:6379/0

APP_ENV=dev
LOG_LEVEL=INFO
TEMP_STORAGE_DIR=./var/tmp_uploads
MAX_FILE_SIZE_MB=20
ALLOW_USER_DOWNLOADS=false
ALLOW_USER_FOLDER_SELECTION=true
REJECTED_RETENTION_DAYS=7
UPLOAD_WORKER_POLL_SECONDS=2
UPLOAD_WORKER_LEASE_SECONDS=600
UPLOAD_WORKER_HEARTBEAT_SECONDS=30

WEBAPP_URL=
WEBAPP_AUTH_MAX_AGE_SECONDS=86400
CORS_ORIGINS=[]
TELEGRAM_OUTBOX_POLL_SECONDS=1
TELEGRAM_OUTBOX_LEASE_SECONDS=60
TELEGRAM_OUTBOX_MAX_ATTEMPTS=10
TELEGRAM_OUTBOX_BASE_RETRY_SECONDS=2
TELEGRAM_OUTBOX_MAX_RETRY_SECONDS=900
