TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789
YANDEX_DISK_TOKEN=
YANDEX_DISK_ROOT=disk:/Telegram Uploads
DATABASE_URL=postgresql+asyncpg://bot:bot@localhost:5432/bot
REDIS_URL=redis://localhost:6379/0
APP_ENV=dev
LOG_LEVEL=INFO
TEMP_STORAGE_DIR=./var/tmp_uploads
MAX_FILE_SIZE_MB=20
ALLOW_USER_DOWNLOADS=false
ALLOW_USER_FOLDER_SELECTION=true
REJECTED_RETENTION_DAYS=7
